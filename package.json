{
  "name": "reactive-route",
  "author": "Dmitry Kazakov",
  "license": "MIT",
  "version": "1.0.0",
  "description": "A reactive, framework-agnostic router in 2 KB",
  "keywords": [
    "router",
    "routing",
    "reactive",
    "typescript",
    "react",
    "preact",
    "solid",
    "vue",
    "ssr"
  ],
  "homepage": "https://dkazakov8.github.io/reactive-route/",
  "bugs": {
    "url": "https://github.com/dkazakov8/reactive-route/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkazakov8/reactive-route.git"
  },
  "type": "module",
  "scripts": {
    "clear-modules": "rm -rf ./node_modules ./examples/*/node_modules ./scripts/measureApps/node_modules",
    "upd": "pnpm run clear-modules && pnpm i --prefer-offline",
    "updg": "pnpm run clear-modules && pnpm i --prefer-offline --ignore-pnpmfile",
    "build": "rm -rf ./dist && vue-tsc -b tsconfig.build.json && node ./scripts/build.ts",
    "npm-publish": "pnpm run build && cd ./dist && npm publish --tag latest && cd ../",
    "analyze": "biome check --no-errors-on-unmatched --write . && tsgo -p tsconfig.type-tests.json --noEmit && tsgo -p tsconfig.analyze.json && vue-tsc -b tsconfig.build.json && tsgo -p examples/react && tsgo -p examples/preact && tsgo -p examples/solid && vue-tsc -p examples/vue",
    "prepare": "husky",
    "up": "bash -c 'pnpm upgrade -r $@' bash",
    "ncu": "pnpm outdated",
    "test": "vitest --clearCache && vitest run",
    "test-watch": "vitest --clearCache && vitest --coverage=false --reporter=default",
    "e2e": "playwright test",
    "docs:dev": "vitepress dev vitepress",
    "docs:preview": "pnpm run docs:build && vitepress preview vitepress",
    "docs:build": "vitepress build vitepress --outDir docs",
    "full-check": "pnpm run analyze && pnpm run build && pnpm run test && pnpm run e2e"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@biomejs/biome": "2.4.10",
    "@espcom/esbuild-plugin-replace": "1.3.2",
    "@playwright/test": "1.61.1",
    "@preact/preset-vite": "2.10.5",
    "@solidjs/testing-library": "0.8.10",
    "@types/markdown-it": "14.1.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "babel-preset-solid": "1.9.12",
    "baseline-browser-mapping": "2.10.40",
    "esbuild": "0.28.0",
    "husky": "9.1.7",
    "kr-observable": "3.2.2",
    "mobx": "6.16.1",
    "mobx-preact": "3.0.0",
    "mobx-react-lite": "4.1.1",
    "playwright": "1.61.1",
    "preact": "10.29.3",
    "preact-render-to-string": "6.7.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "solid-js": "1.9.13",
    "typescript": "6.0.2",
    "@typescript/native-preview": "7.0.0-dev.20260627.2",
    "unplugin-vue": "7.1.1",
    "vitepress": "2.0.0-alpha.16",
    "vitest": "4.0.18",
    "vitest-browser-preact": "1.0.0",
    "vitest-browser-react": "2.2.0",
    "vitest-browser-vue": "2.1.0",
    "vue": "3.5.32",
    "vue-tsc": "3.3.5"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
