{
  "name": "reactive-route",
  "author": "Dmitry Kazakov",
  "license": "MIT",
  "version": "0.0.1-alpha.30",
  "description": "Reactive Router for different frameworks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkazakov8/reactive-route.git"
  },
  "scripts": {
    "upd": "rm -rf ./node_modules&&pnpm i --prefer-offline",
    "build": "rm -rf ./dist&&node --import tsx ./scripts/build.ts&&tsc -b tsconfig.react.json --noEmit false&&tsc -b ./tsconfig.solid.json --noEmit false",
    "npm-publish": "pnpm run build&&cd ./dist&&npm publish --access public --tag alpha&&cd ../",
    "analyze:js": "biome check --no-errors-on-unmatched .",
    "format:js": "biome check --no-errors-on-unmatched --write",
    "check-types": "tsc --project tsconfig.json&&tsc --project tsconfig.solid.json",
    "check-types-example": "tsc --project examples/react/tsconfig.json&&tsc --project examples/preact/tsconfig.json&&tsc --project examples/solid/tsconfig.json&&vue-tsc --project examples/vue/tsconfig.json",
    "prepare": "husky",
    "upgrade-examples": "pnpm upgrade -r reactive-route@latest",
    "up": "bash -c 'pnpm upgrade -r $@' bash",
    "test": "vitest run&&node --import tsx ./scripts/genCoverageBadge.ts",
    "test-watch": "vitest --coverage=false",
    "e2e": "playwright test --config ./e2e/runner.ts",
    "docs:dev": "vitepress dev vitepress",
    "docs:build": "vitepress build vitepress --outDir docs"
  },
  "lint-staged": {
    "(*.js|*.ts|*.tsx|*.mjs)": [
      "pnpm run format:js"
    ]
  },
  "resolutions": {
    "@mongodb-js/zstd": "2.0.1"
  },
  "dependencies": {
    "history": "5.3.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.4",
    "@babel/preset-env": "7.28.3",
    "@babel/preset-typescript": "7.27.1",
    "@biomejs/biome": "2.2.5",
    "@espcom/esbuild-plugin-compress": "1.2.0",
    "@espcom/esbuild-plugin-replace": "1.3.2",
    "@playwright/test": "1.56.1",
    "@preact/preset-vite": "2.10.2",
    "@solidjs/testing-library": "0.8.10",
    "@testing-library/preact": "3.2.4",
    "@testing-library/react": "16.3.0",
    "@testing-library/vue": "8.1.0",
    "@types/babel__core": "7.20.5",
    "@types/lodash": "4.17.20",
    "@types/node": "24.7.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitest/coverage-istanbul": "3.2.4",
    "@vue/test-utils": "2.4.6",
    "babel-preset-solid": "1.9.9",
    "badge-maker": "5.0.2",
    "@vitejs/plugin-vue": "6.0.1",
    "esbuild": "0.25.11",
    "husky": "9.1.7",
    "vue-tsc": "3.1.3",
    "jsdom": "27.1.0",
    "kr-observable": "3.1.12",
    "lint-staged": "16.2.4",
    "lodash": "4.17.21",
    "mobx": "6.15.0",
    "mobx-preact": "3.0.0",
    "mobx-react-lite": "4.1.1",
    "playwright": "1.56.1",
    "preact": "10.27.2",
    "preact-render-to-string": "6.6.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "solid-js": "1.9.10",
    "tsx": "4.20.6",
    "typescript": "5.9.2",
    "unplugin-vue": "7.0.2",
    "vite-plugin-babel": "1.3.2",
    "vite-tsconfig-paths": "5.1.4",
    "vitepress": "2.0.0-alpha.12",
    "vitepress-plugin-group-icons": "1.6.4",
    "vitest": "3.2.4",
    "vue": "3.5.24",
    "xml-splitter": "1.2.1"
  },
  "engines": {
    "node": ">=22"
  }
}