{
  "name": "reactive-route",
  "author": "Dmitry Kazakov",
  "license": "MIT",
  "version": "0.0.1-alpha.22",
  "description": "Reactive Router for different frameworks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkazakov8/reactive-route.git"
  },
  "scripts": {
    "upd": "rm -rf ./node_modules&&pnpm i --prefer-offline",
    "build": "rm -rf ./dist&&node --import tsx ./scripts/build.ts&&tsc -b ./tsconfig.types.react.json&&tsc -b ./tsconfig.types.solid.json",
    "test": "vitest run&&node --import tsx ./scripts/genCoverageBadge.ts",
    "test-watch": "vitest --coverage=false",
    "npm-publish": "pnpm run build&&pnpm run test&&npm publish --access public",
    "analyze:js": "biome check --no-errors-on-unmatched .",
    "format:js": "biome check --no-errors-on-unmatched --write",
    "check-types": "tsc --project tsconfig.json&&tsc --project tsconfig.solid.json",
    "check-types-example": "tsc --project examples/react/tsconfig.json",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "(*.js|*.ts|*.tsx|*.mjs)": [
      "pnpm run format:js"
    ]
  },
  "dependencies": {
    "history": "5.3.0"
  },
  "devDependencies": {
    "@types/babel__core": "7.20.5",
    "@babel/core": "7.28.4",
    "@babel/preset-env": "7.28.3",
    "@babel/preset-typescript": "7.27.1",
    "babel-preset-solid": "1.9.9",
    "vite-plugin-babel": "1.3.2",
    "@biomejs/biome": "2.2.2",
    "@espcom/esbuild-plugin-replace": "1.3.1",
    "@solidjs/testing-library": "0.8.10",
    "@testing-library/react": "16.3.0",
    "@testing-library/preact": "3.2.4",
    "@types/lodash": "4.17.16",
    "@types/node": "22.14.1",
    "@vitest/coverage-istanbul": "3.2.4",
    "@preact/preset-vite": "2.10.2",
    "badge-maker": "5.0.2",
    "esbuild": "0.25.10",
    "husky": "9.1.7",
    "kr-observable": "3.1.4",
    "lint-staged": "16.1.6",
    "lodash": "4.17.21",
    "mobx": "6.13.7",
    "mobx-preact": "3.0.0",
    "mobx-react-lite": "4.1.0",
    "react": "19.1.1",
    "preact": "10.27.2",
    "preact-render-to-string": "6.6.1",
    "solid-js": "1.9.9",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vitepress": "1.6.4",
    "vitepress-plugin-group-icons": "1.6.3",
    "vitest": "3.2.4",
    "xml-splitter": "1.2.1"
  },
  "packageManager": "pnpm@10.9.0",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "require": "./dist/cjs/react/index.js",
      "import": "./dist/esm/react/index.js"
    },
    "./preact": {
      "types": "./dist/preact/index.d.ts",
      "require": "./dist/cjs/preact/index.js",
      "import": "./dist/esm/preact/index.js"
    },
    "./solid": {
      "types": "./dist/solid/index.d.ts",
      "require": "./dist/cjs/solid/index.js",
      "import": "./dist/esm/solid/index.js"
    },
    "./adapters/mobx-react": {
      "types": "./dist/adapters/mobx-react.d.ts",
      "require": "./dist/cjs/adapters/mobx-react/index.js",
      "import": "./dist/esm/adapters/mobx-react/index.js"
    },
    "./adapters/mobx-preact": {
      "types": "./dist/adapters/mobx-preact.d.ts",
      "require": "./dist/cjs/adapters/mobx-preact/index.js",
      "import": "./dist/esm/adapters/mobx-preact/index.js"
    },
    "./adapters/mobx-solid": {
      "types": "./dist/adapters/mobx-solid.d.ts",
      "require": "./dist/cjs/adapters/mobx-solid/index.js",
      "import": "./dist/esm/adapters/mobx-solid/index.js"
    },
    "./adapters/solid": {
      "types": "./dist/adapters/solid.d.ts",
      "require": "./dist/cjs/adapters/solid/index.js",
      "import": "./dist/esm/adapters/solid/index.js"
    },
    "./adapters/kr-observable-react": {
      "types": "./dist/adapters/kr-observable-react.d.ts",
      "require": "./dist/cjs/adapters/kr-observable-react/index.js",
      "import": "./dist/esm/adapters/kr-observable-react/index.js"
    },
    "./adapters/kr-observable-solid": {
      "types": "./dist/adapters/kr-observable-solid.d.ts",
      "require": "./dist/cjs/adapters/kr-observable-solid/index.js",
      "import": "./dist/esm/adapters/kr-observable-solid/index.js"
    },
    "./adapters/kr-observable-preact": {
      "types": "./dist/adapters/kr-observable-preact.d.ts",
      "require": "./dist/cjs/adapters/kr-observable-preact/index.js",
      "import": "./dist/esm/adapters/kr-observable-preact/index.js"
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/core/index.d.ts"
}
