{
  "name": "reactive-route",
  "author": "Dmitry Kazakov",
  "license": "MIT",
  "version": "0.0.1-alpha.7",
  "description": "Reactive Router for different frameworks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkazakov8/reactive-route.git"
  },
  "scripts": {
    "upd": "rm -rf ./node_modules&&pnpm i --prefer-offline",
    "build": "rm -rf ./dist&&node --import tsx ./scripts/build.ts&&tsc -b ./tsconfig.types.json",
    "test": "vitest run&&node --import tsx ./scripts/genCoverageBadge.ts",
    "test-watch": "vitest --coverage=false",
    "npm-publish": "pnpm run build&&pnpm run test&&npm publish --access public",
    "analyze:js": "biome check --no-errors-on-unmatched .",
    "format:js": "biome check --no-errors-on-unmatched --write",
    "check-types": "tsc --project tsconfig.json",
    "check-types-example": "tsc --project examples/react-mobx/tsconfig.json",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "(*.js|*.ts|*.tsx|*.mjs)": [
      "pnpm run format:js"
    ]
  },
  "dependencies": {
    "history": "5.3.0",
    "query-string": "7.1.3"
  },
  "devDependencies": {
    "@babel/core": "7.28.3",
    "@babel/preset-env": "7.28.3",
    "@babel/preset-typescript": "7.27.1",
    "@biomejs/biome": "2.2.2",
    "@espcom/esbuild-plugin-replace": "1.3.0",
    "@solidjs/testing-library": "0.8.10",
    "@testing-library/react": "16.3.0",
    "@types/lodash": "4.17.16",
    "@types/node": "22.14.1",
    "@vitest/coverage-istanbul": "3.2.4",
    "babel-preset-solid": "1.9.9",
    "badge-maker": "5.0.2",
    "esbuild": "0.25.9",
    "global-jsdom": "26.0.0",
    "husky": "9.1.7",
    "kr-observable": "3.0.23",
    "lint-staged": "16.1.6",
    "lodash": "4.17.21",
    "mobx": "6.13.7",
    "mobx-react-lite": "4.1.0",
    "react": "19.1.1",
    "regenerator-runtime": "0.14.1",
    "solid-js": "1.9.9",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vite-plugin-solid": "2.11.8",
    "vitepress": "1.6.4",
    "vitepress-plugin-group-icons": "1.6.3",
    "vitest": "3.2.4",
    "xml-splitter": "1.2.1"
  },
  "packageManager": "pnpm@10.9.0",
  "exports": {
    ".": {
      "types": "./dist/types/core/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    },
    "./react": {
      "types": "./dist/types/react/index.d.ts",
      "require": "./dist/cjs/react/index.js",
      "import": "./dist/esm/react/index.js"
    },
    "./solid": {
      "types": "./dist/types/solid/index.d.ts",
      "require": "./dist/cjs/solid/index.js",
      "import": "./dist/esm/solid/index.js"
    },
    "./adapters/mobx": {
      "types": "./dist/types/adapters/mobx.d.ts",
      "require": "./dist/cjs/adapters/mobx/index.js",
      "import": "./dist/esm/adapters/mobx/index.js"
    },
    "./adapters/solid": {
      "types": "./dist/types/adapters/solid.d.ts",
      "require": "./dist/cjs/adapters/solid/index.js",
      "import": "./dist/esm/adapters/solid/index.js"
    },
    "./adapters/kr-observable": {
      "types": "./dist/types/adapters/kr-observable.d.ts",
      "require": "./dist/cjs/adapters/kr-observable/index.js",
      "import": "./dist/esm/adapters/kr-observable/index.js"
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/core/index.d.ts"
}
