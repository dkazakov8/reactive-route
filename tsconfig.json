{
  "include": ["scripts", "packages", "./*.mjs"],
  "exclude": ["packages/solid"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "dist",
    "module": "commonjs",
    "target": "ES2022",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "reactive-route": ["packages/core/index.ts"],
      "reactive-route/react": ["packages/react/index.ts"],
      "reactive-route/solid": ["packages/solid/index.ts"],
      "reactive-route/adapters/mobx-react": ["packages/adapters/mobx-react.ts"],
      "reactive-route/adapters/mobx-preact": ["packages/adapters/mobx-preact.ts"],
      "reactive-route/adapters/mobx-solid": ["packages/adapters/mobx-solid.ts"],
      "reactive-route/adapters/solid": ["packages/adapters/solid.ts"],
      "reactive-route/adapters/kr-observable-react": ["packages/adapters/kr-observable-react.ts"],
      "reactive-route/adapters/kr-observable-solid": ["packages/adapters/kr-observable-solid.ts"],
      "reactive-route/adapters/kr-observable-preact": ["packages/adapters/kr-observable-preact.ts"]
    }
  },
  "types": ["vite/client", "@testing-library/jest-dom"]
}
