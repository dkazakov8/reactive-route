{
  "include": ["src", "build.ts", "plugins.ts"],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "target": "es2022",
    "module": "es2022",
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler"
  }
}
